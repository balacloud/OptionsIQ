# OptionsIQ — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# --- REQUIRED ---
# Your IBKR paper/live account size (used for 1% risk position sizing)
ACCOUNT_SIZE=25000

# --- IBKR Connection ---
IB_HOST=127.0.0.1
IB_PORT=4001
IB_CLIENT_ID=1

# --- Optional: Alpha Vantage (for news sentiment in STA context) ---
# ALPHA_VANTAGE_API_KEY=your_key_here

# --- STA Integration ---
STA_BASE_URL=http://localhost:5001
